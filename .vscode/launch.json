{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Game",
      "request": "launch",
      "type": "editor-browser",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start Vite Dev Server",
      "postDebugTask": "Stop Vite Dev Server"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run as Desktop App (Dev)",
      "program": "${workspaceFolder}/src-tauri/target/debug/my-app-package-name",
      "args": [],
      "cwd": "${workspaceFolder}",
      "terminal": "console",
      "preLaunchTask": "Cargo Build (Desktop Dev)",
      "postDebugTask": "Stop Vite Desktop Server"
    },
    {
      "name": "Debug Game Preview",
      "request": "launch",
      "type": "editor-browser",
      "url": "http://localhost:4173",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start Vite Preview Server",
      "postDebugTask": "Stop Vite Preview Server"
    }
  ]
}
