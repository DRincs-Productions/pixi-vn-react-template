{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Game",
      "request": "launch",
      "type": "editor-browser",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start Vite Dev Server",
      "postDebugTask": "Stop Vite Dev Server"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run as Desktop App (Dev)",
      "cargo": {
        "args": [
          "build",
          "--manifest-path=./src-tauri/Cargo.toml",
          "--no-default-features"
        ]
      },
      "preLaunchTask": "ui:dev"
    },
    {
      "name": "Debug Game Preview",
      "request": "launch",
      "type": "editor-browser",
      "url": "http://localhost:4173",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start Vite Preview Server",
      "postDebugTask": "Stop Vite Preview Server"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run as Desktop App (Preview)",
      "cargo": {
        "args": ["build", "--release", "--manifest-path=./src-tauri/Cargo.toml"]
      },
      "preLaunchTask": "ui:build"
    }
  ]
}
