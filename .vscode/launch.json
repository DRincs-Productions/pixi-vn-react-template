{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Game",
      "request": "launch",
      "type": "editor-browser",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*",
        "/src/*": "${workspaceFolder}/src/*"
      },
      "preLaunchTask": "Start Vite Dev Server",
      "postDebugTask": "Stop Vite Dev Server"
    },
    {
      "name": "Debug Game Preview",
      "request": "launch",
      "type": "editor-browser",
      "url": "http://localhost:4173",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*",
        "/src/*": "${workspaceFolder}/src/*"
      },
      "preLaunchTask": "Start Vite Preview Server",
      "postDebugTask": "Stop Vite Preview Server"
    }
  ]
}
